# Copiloto Administrativo Agéntico — Universidad de Antioquia
# Copia este archivo a .env y completa los valores antes de ejecutar el sistema.

# ── LLM PRINCIPAL (GRATUITO) ─────────────────────────────────────────────────
# API Key de Groq — GRATUITA en https://console.groq.com
# Límites: 14,400 requests/día, sin tarjeta de crédito requerida
GROQ_API_KEY=

# ── EMBEDDINGS (OPCIONAL) ────────────────────────────────────────────────────
# API Key de OpenAI para embeddings text-embedding-3-small (opcional).
# Si no está configurada, el sistema usa sentence-transformers gratis (offline).
OPENAI_API_KEY=

# ── RUTAS DEL SISTEMA ────────────────────────────────────────────────────────
# Ruta donde ChromaDB persiste los vectores
CHROMA_PATH=data/chroma_db

# Ruta al archivo de trámites estructurados
TRAMITES_PATH=data/tramites/tramites.json
